class Solution {
    public boolean canMakeArithmeticProgression(int[] arr) {

        Arrays.sort(arr);
        int n = arr.length-2;
        int i = 0;

        while (i < n) {
            if (Math.abs(arr[i] - arr[i + 1]) != Math.abs(arr[i+1] - arr[i+2]))
                return false;

            i++;
        }
        return true;


