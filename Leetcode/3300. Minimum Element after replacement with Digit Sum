class Solution {
    public int minElement(int[] nums) {
        int min = Integer.MAX_VALUE;
        for (int num : nums) {
            int s = 0;
            while (num > 0) {
                s += num % 10;
                num /= 10;
            }
            min = Math.min(min, s);
        }
        return min;
    }
}
