class Solution {
    public long removeZeros(long n) {
        String s = String.valueOf(n);
        String ans = "";
        for (int i = 0; i < s.length(); i++) {
            char ch = s.charAt(i);
            if (ch != '0')
                ans += ch;
        }
        return Long.parseLong(ans);

        // return Long.parseLong((n+"").replace("0",""));
    }
}
