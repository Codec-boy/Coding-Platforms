class Solution {
    public int numSpecial(int[][] mat) {
        int count = 0;
        int m = mat.length;
        int n = mat[0].length;

        int[] rowcount = new int[m];
        int[] colcount = new int[n];
 
        for(int i = 0;i<m;i++){
            for(int j=0;j<n;j++){
                if(mat[i][j] == 1){
                    rowcount[i]++;
                    colcount[j]++;
                }
            }
        }
        for(int i = 0;i<m;i++){
            for(int j =0;j<n;j++){
                if(mat[i][j] == 1 && rowcount[i] == 1 && colcount[j] == 1 ){
                    count ++;
                }
            }
        }
        return count;
    }
}
