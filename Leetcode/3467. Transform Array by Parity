class Solution {
    public int[] transformArray(int[] nums) {
        //int[] ans = new int[nums.length];
        for (int i = 0; i < nums.length; i++) {
            if (nums[i] % 2 == 0) {
                //ans[i] = 0;
                nums[i] = 0;
            } else {
                //ans[i] = 1;
                nums[i] = 1;
            }
        }
        //Arrays.sort(ans);
        Arrays.sort(nums);
        //return ans;
        return nums;
    }
}

