class Solution {
    public boolean checkGoodInteger(int n) {
        int sum = 0;
        int sqsum = 0;
        while (n > 0) {
            int r = n % 10;
            sum += r;
            sqsum += r * r;
            n /= 10;
        }
        if (sqsum - sum >= 50)
            return true;
        return false;
    }
}
