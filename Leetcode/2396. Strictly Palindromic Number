class Solution {
    public boolean isStrictlyPalindromic(int n) {
        // return false;

        for (int i = 2; i <= n - 2; i++) {
            String s = Integer.toString(n, i);
            StringBuilder res = new StringBuilder(s);
            res.reverse();
            if (!s.equals(res.toString()))
                return false;
        }
        return true;
    }
}
