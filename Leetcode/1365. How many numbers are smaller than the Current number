class Solution {
    public int[] smallerNumbersThanCurrent(int[] nums) {
        int n = nums.length;
        int[] res = new int[n];

        for (int i = 0; i < n; i++) {
            int smallcount = 0;

            for (int j = 0; j < n; j++) {
                if (nums[j] < nums[i] && j != i) {
                    smallcount++;
                }
            }

            res[i] = smallcount;
        }
        return res;
    }
}
